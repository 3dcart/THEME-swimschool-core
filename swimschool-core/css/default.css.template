.floating-cart {
    position: fixed;
    top: 50%;
    right: 0;
    z-index: 999;
    background-color: #101010;
    color: #fff;
    border-radius: 20px 0 0 20px;
    padding: 15px;
    text-align: center;
    width: 90px;
    display: none;
}
.floating-cart a,
.floating-cart a:hover {
    color: #ececec;
    text-decoration: none;
}
.floating-cart a:hover {
    opacity: 0.6;
}
.floating-cart span.cart-icon {
    display: block;
    font-size: 30px;
    line-height: 1;
}
.floating-cart span.cart-details {
    font-size: 12px;
    text-transform: none;
    display: block;
    margin: 5px 0 0;
}

.paging {
    float: right;
}
.paging strong, 
.paging a {}
.paging strong,
.paging a:hover {
    color: #fff;
    background-color: #0f0f0f;
    text-decoration: none;
}
.readmore{
    font-size: 15px;
    color: #999;
}
.page_heading, ul.sidebarUL > li, .sidebar-widget .topsellers-item:not(:last-child), .sidebar-widget .new-release-item:not(:last-child){
    border: none;
}
.page_heading:after{
    display: none;
}
.page_heading{
    font-family: 'Architects Daughter', cursive;
    color: #[headings_color];
}
#frmsortby h2, .sort-by span{
    font-family: 'Montserrat', sans-serif;
    font-size: 14px;
    color: #03b2d9;
}
.breadcrumnb ol li > a{
