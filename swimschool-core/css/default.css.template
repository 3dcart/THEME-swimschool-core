#listing .product-details .page_headers, #quickView #add .page_headers{
    font-family: 'Architects Daughter', cursive;
    font-size: 24px;
    line-height: 1.6;
    letter-spacing: 0px;
    color: #[headings_color];
}
#listing .short-description{
    color: #2c3e50;
    font-weight: 400;
}
.listing-holder, .listing-holder > div:first-child{
    padding: 0 20px 0 0;
}
.listing-holder > div:last-child{
    padding: 0;
}
#listing .pricingBlock{
    width: 100%;
    background: #f4f3f3;
    padding: 40px 0;
    margin-top: 51px;
    text-align: center;
}
#divOptionsBlock{
    padding: 0;
}
#divOptionsBlock .header{
    position: relative;
    width: 100%;
    float: left;
}
#divOptionsBlock .header:after{
    content: "";
    width: 100%;
    height: 1px;
    background-color: #ccc;
    position: absolute;
    top: 9px;
    left: 0;
}
#divOptionsBlock .page_heading {
    float: left;
    position: relative;
    background-color: #fff;
    padding-right: 10px;
    font-weight: normal;
    font-size: 18px;
    color: #[headings_color];
    z-index: 9;
}
.relatedBlock .page_heading{
    font-family: 'Montserrat', sans-serif;
    font-size: 18px;
    border-bottom: 1px solid #ccc;
    text-transform: capitalize;
    font-weight: 400;
}
#listing .addToCartBlock{
    text-align: right;
    margin-right: 20px;
}
#listing .addToCartBlock .qtybox-addcart > *{
    display: none;
}
#listing .addToCartBlock .btn-addcart{
    padding: 5px 0;
    text-transform: uppercase;
    color: #fff;
    width: 144px;
    height: 32px;
    font-weight: normal;
    font-family: 'Raleway', sans-serif;
    font-size: 12px;
    text-align: center;
    display: inline-block !important;
}
#listing .addToCartBlock .btn-addcart:hover{
    color: #000;
    background-color: #03b2d9;
}
.pricingBlock .yourprice, .pricingBlock .saleprice{
    font-size: 24px;
    /*color: #2d4dae;*/
    font-weight: 500;
    font-family: 'Work Sans', sans-serif;
    text-transform: capitalize;
}
.head-mobile-nav > a{
    color: #337ab7;
}
.qty-format-list{
    padding: 5px 0 10px 0;
    font-family: 'Architects Daughter', cursive;
    font-weight: normal;
    font-size: 18px;
    line-height: 24px;
    border-bottom: 1px solid #ccc;
    margin-bottom: 10px;
}
.qty-format-list .qty-format{
    float: right;
}
.qty-format-list .qty-format span{
    margin-right: 20px;
} 
.qty-format-list .qty-format > *{
    display: inline-block;
    width: auto;
}
.qty-format-list input{
    text-align: center;
}
@media(max-width: 1200px){
    .mailinglist-input.form-control{
        font-size: 16px;
    }
    .mailist-box{
        max-width: 100%;
    }
    .mailist-box h3,.mailist-box h2{
        font-size: 32px;
    }
    .navbar-inverse .navbar-nav > li > a{
        padding: 0 8px;
    }
    .header-right img{
        height: 40px;
    }
}



@media(max-width: 1024px){
    .mailist-box{
        padding: 0;
    }
    .navbar.navbar-inverse{
        margin-top: 23px;
    }
    .navbar-inverse .navbar-toggle{
        border-color: #[btn_border];
        background:  #[btn_color] !important;
    }
    .navbar-inverse .navbar-toggle .icon-bar{
        background-color: #[btn_text_color];
    }
}

@media(max-width: 991px){
    .mailinglist-form{
        padding: 0 20px;
    }
    .mailinglist-input.form-control{
        font-size: 14px;
    }
    .mailinglist-submit{
        min-width: 120px;
        font-size: 18px;        
