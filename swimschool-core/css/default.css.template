/*
** Bootstrap over-rides
*/
body {
	display: flex;
	height: 100%;
	flex-direction: column;
	min-height: 100vh;
}
#skip a
{
position:absolute;
left:-10000px;
top:auto;
width:1px;
height:1px;
overflow:hidden;
}
#skip a:focus
{
position:static;
width:auto;
height:auto;
}
.page-content {
	flex: 1 0 auto;
}
footer {
	flex-shrink: 0;
}
.sub-section{
	clear:both;
}
.product-items.productList .product-item .product-content {
    text-align: left;
}
.product-items.productList .product-item .img a {
    position: initial;
}
.product-items.productList .product-item .img {
    border:1px solid #ececec;
}
.homepage-blog-posts .post-image-container img {
    height: 205px;
}
.homepage-blog-posts div#postContent {
    height: 127px;
}
.product-items.productList .product-item .name{
	border-bottom:none;
	text-align: left;
}
.product-items.productList .product-item .action .btn {
    max-width: 180px;
}
@media (max-width: 991px){
.product-items.productList .product-item .img {
    padding-right: 0;
    width: 32%;
}
}
@media(max-width:767px){
	.homepage-blog-posts .post-image-container img,
	.homepage-blog-posts .post-image-container,
	.homepage-blog-posts div#postContent{
		height: auto;
		min-height: auto;
	}
}
body {
    font-family: 'Montserrat', sans-serif;
    color: #[body_text_color];
    line-height: 1.5;
    font-size: [base_font_size]px;
}
h1 {
    font-size: [heading_base_size]px;
}

.titles {
    margin: 0 0 20px;
    font-size: 18px;
    font-weight: 600;
    letter-spacing: 0;
}

.subcategories {
    border-bottom: 1px solid #ececec;
    padding: 0 0 30px;
}
.subcategories > ul > li > a {
    color: #000;
    text-decoration: none;
    display: block;
    -webkit-transition: all .25s ease-out;
    transition: all .25s ease-out;
}
.subcategories > ul > li > a:hover {
    opacity: 0.8;
}
.subcategories > ul > li span.name {
    color: #000;
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
}



@media (min-width: 1200px) {
    .container {
        width: 1200px;
    }
}
.form-control {
    color: #000;
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    height: 36px;
    padding: 7px 12px;
}
.form-control.search-text {
     border:1px solid #ececec;
}

.btn {
    font-size: 13px;
    padding: 8px 12px;
    font-weight: 600;
    text-transform: uppercase;
}
.btn-default {
    border-color: #[btn2_border];
    background-color: #[btn2_color];
    color: #[btn2_text_color];
}
.btn-default:hover,
.btn-default:focus,
.btn-default:hover:focus,
.btn-default.focus {
    border-color: #[btn2_border];
    background-color: #[btn2_color];
    color: #[btn2_text_color];
    opacity: 0.8;
}
.btn-primary,
.btn-inverse {
    color: #[btn_text_color];
    background-color: #[btn_color];
    border-color: #[btn_border];
}
.btn-primary:hover,
.btn-primary:focus, 
.btn-primary:active:focus,
.btn-inverse,
.btn-inverse:focus, 
.btn-inverse:active:focus {
    color: #[btn_text_color];
    background-color: #[btn_color];
    border-color: #[btn_color];
    opacity: 0.8;
}
.navbar.navbar-inverse {
    margin-top: 40px;
    margin-bottom: 0;
    border: none;
    background-color: transparent;
}
.navbar-inverse .navbar-nav > li > a {
    color: #242424;
    font-weight: 500;
    letter-spacing: 0.025em;
    text-transform: uppercase;
    font-size: 14px;
    line-height: 18px;
    /* min-height: 20px; */
    padding: 0 10px;
}
.navbar-inverse .navbar-nav > li > a:hover, .navbar-inverse .navbar-nav > li > a:focus {
    color: #242424;
    opacity: 0.75;
    background-color: rgba(255,255,255,0.2);
}
.header-right{
    text-align: right;
    margin-top: 25px;
}
.header-right li{
    display: inline-block;
    margin-left: 0;
}
.header-right li a:hover{
    opacity: .8;
}
.dropdown-menu > li > a {
    font-size: 12px;
    padding: 6px 20px;
    text-transform: uppercase;
}
.navbar-nav > li.dropdown > a:after {
    content: "\f107";
    font-family: "fontello";
    font-size: 18px;
    line-height: 1;
    margin-left: 5px;
}
@media (max-width: 1023px) {
  .navbar-header {
      float: none;
  }
  .navbar-left,.navbar-right {
      float: none !important;
  }
  .navbar-toggle {
      display: block;
  }
  .navbar-collapse.collapse {
      display: none!important;
  }
  .navbar-nav {
      float: none!important;
  }
  .navbar-nav>li {
      float: none;
  }
  .collapse.in{
      display:block !important;
  }
  .navbar-nav .open .dropdown-menu {
        position: static;
        float: none;
        width: auto;
        margin-top: 0;
        background-color: transparent;
        border: 0;
        -webkit-box-shadow: none;
        box-shadow: none;
    }
    .navbar-inverse .navbar-nav .open .dropdown-menu > li > a {
        color: #9d9d9d;
    }
    .navbar-nav .open .dropdown-menu > li > a {
        line-height: 20px;
    }
    .navbar-nav .open .dropdown-menu > li > a, .navbar-nav .open .dropdown-menu .dropdown-header {
        padding: 5px 15px 5px 25px;
    }
}
/*
** Template code
*/
.logo {
    height: 105px;
    position: relative;
    overflow: hidden;
}
.logo img {
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    margin: auto;
    max-width: 100%;
    max-height: 100%;
}
.logo a:hover img {
    opacity: 0.6;
}
.top-nav {
    background-color: #[nav_color];
}
.top-nav ul {
    padding: 10px 0;
    margin: 0;
    list-style: none;
    font-size: 13px;
    line-height: 1;
    font-family: 'Montserrat', sans-serif;
    text-transform: capitalize;
    font-weight: 600;
}
.top-nav ul li {
    float: left;
    margin-right: 10px;
    padding-right: 10px;
    border-right: 2px solid #[nav_text_color];
}
.top-nav .useraccount ul {
    float: right;
}
.top-nav ul li:last-child {
    border: none;
    margin: 0;
    padding: 0;
}
.top-nav ul li a {
    color: #[nav_text_color];
}
#menulinks li{
    border: none;
}
.site-header {
    padding: 25px 0;
}

.searchBox {
    padding: 10px 0;
}
.search-form {
    position: relative;
}
.search-form .search-text {
    padding: 9px 62px 9px 12px;
    height: 40px;
}
.search-form .search-submit {
    position: absolute;
    top: 0;
    right: 0;
    width: 50px;
    height: 100%;
    text-align: center;
    font-size: 16px;
    background-color: #2d4dae;
    border-color: #2d4dae;
}


.minicart {
    min-width: 165px;
    height: 60px;
    float: right;
    padding: 15px 0 15px 10px;
    border-left: 1px solid #ececec;
}
.minicart-inner {
    display: block;
    color: #000;
    text-transform: uppercase;
    cursor: pointer;
}
.minicart-inner:hover {
    color: #000;
    opacity: 0.8;
}
.minicart .cart-icon {
    display: block;
    width: auto;
    height: 30px;
    line-height: 30px;
    font-size: 30px;
    float: left;
    margin-right: 5px;
}
.minicart .cart-details {
    display: block;
    float: left;
}

span.cart-title {
    font-size: 12px;
    line-height: 15px;
    display: block;
    font-weight: bold;
}
span.cart-count {
    color: #666;
    font-size: 10px;
    display: block;
    line-height: 15px;
    font-weight: 500;
}
.site-footer {
    position: relative;
    background-color: #[footer_color];
    padding: 55px 0 0;
    color: #fff;
    font-family: 'Montserrat', sans-serif;
}
.site-footer:after{
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    margin: auto;
    width: 0;
    height: 0;
    border-left: 15px solid transparent;
    border-right: 15px solid transparent;
    border-top: 15px solid #fff;
}
.site-footer > .container > .row{
    padding-bottom: 30px;
}
ul.extrapages li {
    line-height: 1;
    margin: 0 0 15px;
}
ul.extrapages li a {
    color: #[footer_text_color];
    font-size: 15px;
}
ul.sidebarUL > li > a{
    color: #2d4dae;
}
.footer-social {
}
.social-icons,
.global-footer {
    padding-top: 15px;
    padding-bottom: 15px;
}
.copyright {
    background-color: #fff;
    padding-top: 15px;
    padding-bottom: 0;
    text-align: left;
    color: #000;
    font-size: 12px;
    font-weight: 400;
    /*border-top: 2px solid #03b2d9;*/
}
.copyright a {
    color: #000;
    text-decoration: underline;
}
#divRewardWidget {
    color: #000 !important;
}
.mailinglist-section{
    background: #f4f3f3;
    /*border-bottom: 2px solid #[footer_color];*/
    padding: 60px 0;
}
.mailinglist-form{
    position: relative;
    padding: 0;
}
.mailist-box {
    width: 100%;
    text-align: center;
    margin-bottom: 10px;
}
.mailist-box h3,.mailist-box h2 {
    font-size: 45px;
    line-height: 42px;
    font-family: 'Architects Daughter', cursive;
    margin: 0;
    text-transform: capitalize;
    font-weight: 500;
}
.mailinglist-input.form-control {
    font-family: 'Architects Daughter', cursive;
    background-color: #fff;
    border-color: #ccc;
    max-width: 100%;
    width: 100%;
    color: #b3b3b3;
    float: left;
    font-size: 24px;
    height: 40px;
}
.mailinglist-submit {
    position: absolute;
    top: 0;
    right: 0;color:#000;
    font-family: 'Architects Daughter', cursive;
    float: right;
    min-width: 180px;
    height: 100%;
    /*background-color: #03b2d9;
    border: 1px solid #03b2d9;*/
    font-size: 24px;
    padding: 0;
}
.btn-default.mailinglist-submit:hover, 
.btn-default.mailinglist-submit:focus {
    opacity: 0.6;
}
.mailinglist-response {
    display: none;
}
.maillist-options {
    margin: 15px 0 0;
}
.subscribe {
    float: left;
    margin-right: 20px;
    line-height: 13px;
}
.subscribe input[type="radio"] {
    margin: 0;
    vertical-align: middle;
}
.subscribe label {
    margin: 0;
    font-size: 12px;
    line-height: 13px;
    font-weight: 300;
    margin-left: 3px;
    color: #ccc;
    cursor: pointer;
}

.footer-social ul {
    margin: 0;
}
ul.payment-icons {
    text-align: right;
}
ul.payment-icons li {
    font-size: 34px;
    line-height: 36px;
    vertical-align: middle;
}

ul.payment-icons li.payment-icons-label,
ul.social-icons li.social-icons-label {
    font-size: 24px;
    vertical-align: middle;
    font-family: 'Architects Daughter', cursive;
    text-transform: capitalize;
    margin-right: 20px;
}

.social-icons {
    padding-top: 0;
}
.social-icons li a {
    color: #fff;
    background-color: #55b1db;
    width: 35px;
    height: 35px;
    line-height: 35px;
    border-radius: 100%;
    display: block;
    text-align: center;
    font-size: 20px;
}
.social-icons li a:hover {
    opacity: 0.6;
}


